{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": ".vercel/output",
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["api"]
}
